<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="using:AES_Lacrima.Mini.Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AES_Lacrima.Mini.ViewModels"
             xmlns:conv="using:AES_Lacrima.Converters"
             xmlns:behaviors="using:AES_Lacrima.Behaviors"
             xmlns:composition="using:AES_Controls.Composition"
             xmlns:controlsbehaviors="using:AES_Controls.Behaviors"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AES_Lacrima.Mini.Views.MinView"
             x:DataType="vm:MinViewModel"
             x:Name="MinViewRoot">
    <UserControl.Resources>
        <conv:BoolToStringConverter x:Key="BoolToString" />
        <conv:TimeSpanConverter x:Key="TimeSpanConverter" />
        <conv:ObjectEqualsConverter x:Key="ObjectEqualsConverter" />
    </UserControl.Resources>

    <Grid Background="Transparent" RowDefinitions="Auto,Auto,*,Auto">
        <!-- Thumbnail & Controls -->
        <Grid Grid.Row="0" ColumnDefinitions="50*,Auto" Height="100">
            <!-- right column is Auto so playback controls keep their natural width; left thumbnail/text
                 will shrink first when window narrows. -->
			<Grid Grid.Column="0" ColumnDefinitions="Auto,Auto,*" Margin="0,-10,0,0">
                <Border BorderBrush="DimGray" Background="{Binding ControlsBrush}" BorderThickness="1" Margin="10,0,10,10" Height="80" Width="80" ClipToBounds="True">
					<Image Source="{Binding LoadedMediaItem.CoverBitmap}"/>
                </Border>
				<StackPanel Grid.Column="2" VerticalAlignment="Top" Spacing="5" Margin="0,10,5,0" ClipToBounds="True">
					<TextBlock Text="{Binding MusicViewModel.AudioPlayer.IsPlaying, Converter={StaticResource BoolToStringConverter}, ConverterParameter='PLAYING, PAUSED'}"
							   FontSize="12"
							   Foreground="#b8b8b8"/>
					<TextBlock Text="{Binding LoadedMediaItem.Title, FallbackValue='No File Loaded'}"
							   FontSize="14"
					   Foreground="LightGray">
						<Interaction.Behaviors>
							<behaviors:MarqueeBehavior />
						</Interaction.Behaviors>
					</TextBlock>
                    <TextBlock Text="{Binding LoadedMediaItem.Album, FallbackValue=''}"
                               FontSize="12"
                               Foreground="#99FFFFFF"
                               TextWrapping="Wrap"
							   MaxLines="1"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock FontSize="14"
                               Foreground="White">
                        <Run Text="{Binding MusicViewModel.AudioPlayer.Position, Converter={StaticResource TimeSpanConverter}, FallbackValue='00:00'}" />
                        <Run Text=" / " />
                        <Run Text="{Binding LoadedMediaItem.Duration, Converter={StaticResource TimeSpanConverter}, FallbackValue='00:00'}" />
                    </TextBlock>
				</StackPanel>
            </Grid>
            <StackPanel Grid.Column="1">
                <StackPanel HorizontalAlignment="Stretch" VerticalAlignment="Center" Spacing="5" Margin="0,0,15,0">
					<!-- use Auto,Auto so each section measures to its content; prevents playback
					     buttons from compressing when the overall width shrinks -->
					<Grid ColumnDefinitions="Auto,Auto">
                        <!-- Playback controls -->
                        <StackPanel Margin="0,5,0,0" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left" VerticalAlignment="Center">
                            
                            <!-- Repeat button -->
                            <Button Height="25"
                                    Width="25"
                                    VerticalAlignment="Center"
                                    Cursor="Hand"
                                    Command="{Binding MusicViewModel.ToggleRepeatCommand}"
                                    ToolTip.Tip="{Binding MusicViewModel.NextRepeatToolTip}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent" BorderThickness="0">
                                            <ContentPresenter Content="{TemplateBinding Content}"
                                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <Viewbox Stretch="Uniform">
                                    <Grid>
                                        <!-- Default repeat icon (visible when not in Shuffle mode) -->
                                        <Canvas Width="120" Height="120" ClipToBounds="False" IsVisible="{Binding !ShuffleMode}">
                                            <!-- Top handle -->
                                            <Path Data="M 15,65 V 45 C 15,30 15,30 30,30 H 105 M 105,30 L 88,14 M 105,30 L 88,46"
                                                  Stroke="{Binding MusicViewModel.AudioPlayer.Loop, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#F0F0F0,DimGray'}"
                                                  StrokeThickness="11" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" />
                                            <!-- Bottom handle -->
                                            <Path Data="M 105,55 V 75 C 105,90 105,90 90,90 H 15 M 15,90 L 32,74 M 15,90 L 32,106"
                                                  Stroke="{Binding MusicViewModel.AudioPlayer.Loop, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#F0F0F0,DimGray'}"
                                                  StrokeThickness="11" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent" />

                                        <!-- indicator for Repeat One state -->
                                        <Grid Width="{Binding Width, RelativeSource={RelativeSource AncestorType=Canvas}}"
                                              Height="{Binding Height, RelativeSource={RelativeSource AncestorType=Canvas}}"
                                              Canvas.Left="0" Canvas.Top="0" IsHitTestVisible="False">
                                            <TextBlock Text="1"
                                                       Foreground="{Binding MusicViewModel.AudioPlayer.Loop, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#F0F0F0,DimGray'}"
                                                       FontSize="32"
                                                       FontWeight="Heavy"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       IsVisible="{Binding MusicViewModel.AudioPlayer.IsRepeatOne}"/>
                                        </Grid>
                                        </Canvas>

                                        <!-- When Shuffle mode is active, show the shuffle icon on the repeat button -->
                                        <Canvas Width="140" Height="120" IsVisible="{Binding ShuffleMode}">
                                            <Path Data="M 10,25 L 35,25 C 70,25 70,95 105,95 L 115,95"
                                                  Stroke="White"
                                                  StrokeThickness="14"
                                                  StrokeLineCap="Round"
                                                  Fill="Transparent" />

                                            <Path Data="M 10,95 L 35,95 C 70,95 70,25 105,25 L 115,25"
                                                  Stroke="White"
                                                  StrokeThickness="14"
                                                  StrokeLineCap="Round"
                                                  Fill="Transparent" />

                                            <Path Data="M 100,5 L 135,25 L 100,45 Z" Fill="White" />

                                            <Path Data="M 100,75 L 135,95 L 100,115 Z" Fill="White" />
                                        </Canvas>
                                    </Grid>
                                </Viewbox>
                            </Button>

                            <!-- Stop button -->
                            <Button Width="26"
                                    Height="26"
                                    VerticalAlignment="Center"
                                    Cursor="Hand"
                                    ToolTip.Tip="Stop"
                                    Command="{Binding StopCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent" BorderThickness="0">
                                            <ContentPresenter Content="{TemplateBinding Content}"
                                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <Viewbox Stretch="Uniform">
                                    <Canvas Width="100" Height="100">
                                        <!-- Stop square -->
                                        <Rectangle Canvas.Left="25" Canvas.Top="25" Width="50" Height="50" Fill="White" RadiusX="4" RadiusY="4" />
                                    </Canvas>
                                </Viewbox>
                            </Button>

                            <!-- Previous button -->
                            <Button Height="26"
                                    Width="26"
                                    VerticalAlignment="Center"
                                    Cursor="Hand"
                                    ToolTip.Tip="Previous"
                                    Command="{Binding PreviousCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent" BorderThickness="0">
                                            <ContentPresenter Content="{TemplateBinding Content}"
                                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <Viewbox Stretch="Uniform">
                                    <Canvas Width="100" Height="100">
                                        <!-- Vertical bar -->
                                        <Rectangle Canvas.Left="10" Canvas.Top="15" Width="12" Height="70" RadiusX="6" RadiusY="6" Fill="White" />
                                        <!-- Left pointing triangle -->
                                        <Path Data="M 85,15 L 35,50 L 85,85 Z" Fill="White" />
                                    </Canvas>
                                </Viewbox>
                            </Button>

                            <!-- Play button -->
                            <Button Width="48"
                                    Height="48"
                                    VerticalAlignment="Center"
                                    Cursor="Hand"
                                    ToolTip.Tip="{Binding MusicViewModel.AudioPlayer.IsPlaying, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Pause, Play'}"
                                    Command="{Binding PlayPauseCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent" BorderThickness="0">
                                            <ContentPresenter Content="{TemplateBinding Content}"
                                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <Viewbox Stretch="Uniform">
                                    <Canvas Width="100" Height="100">
                                        <!-- Outer circle -->
                                        <Ellipse Canvas.Left="4" Canvas.Top="4" Width="92" Height="92" Stroke="White" StrokeThickness="7" />
                                        <!-- Pause icon (two bars) -->
                                        <Rectangle Canvas.Left="35" Canvas.Top="30" Width="10" Height="40" RadiusX="4" RadiusY="4" Fill="White" IsVisible="{Binding MusicViewModel.AudioPlayer.IsPlaying}" />
                                        <Rectangle Canvas.Left="55" Canvas.Top="30" Width="10" Height="40" RadiusX="4" RadiusY="4" Fill="White" IsVisible="{Binding MusicViewModel.AudioPlayer.IsPlaying}" />
                                        <!-- Play icon (triangle) -->
                                        <Path Data="M 38,30 L 72,50 L 38,70 Z" Fill="White" IsVisible="{Binding !MusicViewModel.AudioPlayer.IsPlaying}" />
                                    </Canvas>
                                </Viewbox>
                            </Button>

                            <!-- Next -->
                            <Button Height="26"
                                    Width="26"
                                    VerticalAlignment="Center"
                                    Cursor="Hand"
                                    ToolTip.Tip="Next"
                                    Command="{Binding NextCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent" BorderThickness="0">
                                            <ContentPresenter Content="{TemplateBinding Content}"
                                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <Viewbox Stretch="Uniform">
                                    <Canvas Width="100" Height="100">
                                        <!-- Right pointing triangle -->
                                        <Path Data="M 15,15 L 65,50 L 15,85 Z" Fill="White" />
                                        <!-- Vertical bar -->
                                        <Rectangle Canvas.Left="78" Canvas.Top="15" Width="12" Height="70" RadiusX="6" RadiusY="6" Fill="White" />
                                    </Canvas>
                                </Viewbox>
                            </Button>

                            <!-- Volume (toggle visual only) -->
                            <Button Height="26"
                                    Width="26"
                                    VerticalAlignment="Center"
                                    Cursor="Hand"
                                    ToolTip.Tip="Mute"
                                    Margin="0,0,15,0">
                                <Button.Flyout>
                                  <Flyout>
                                    <StackPanel>
                                        <Label Foreground="White" FontSize="12" HorizontalAlignment="Center"
                                               Content="{Binding MusicViewModel.AudioPlayer.Volume, StringFormat='Volume: {0:0}%', FallbackValue='Volume: 0%'}" />
								        <composition:CompositionSlider Height="20"
                                                                       Width="100"
                                                                       SliderTrackHeight="10"
                                                                       ExecuteDuringDrag="True"
                                                                       Maximum="100"
                                                                       Minimum="0"
                                                                       SmallThumb="True"
                                                                       Value="{Binding MusicViewModel.AudioPlayer.Volume, Mode=TwoWay}"/>
                                    </StackPanel>
                                  </Flyout>
                                </Button.Flyout>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent" BorderThickness="0">
                                            <ContentPresenter Content="{TemplateBinding Content}"
                                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <Viewbox Stretch="Uniform">
                                    <Canvas Width="120" Height="100">
                                        <!-- Speaker box -->
                                        <Rectangle Canvas.Left="10" Canvas.Top="34" Width="22" Height="32" RadiusX="4" RadiusY="4" Fill="White" />
                                        <!-- Speaker cone -->
                                        <Path Data="M32,34 L52,18 L52,82 L32,66 Z" Fill="White" />

                                        <!-- Sound waves (visible when not muted) -->
                                        <Path Data="M 64,36 A 14,14 0 0 1 64,64" Stroke="White" StrokeThickness="6" StrokeLineCap="Round"
                                              IsVisible="{Binding !IsMuted}" />
                                        <Path Data="M 76,26 A 28,28 0 0 1 76,74" Stroke="White" StrokeThickness="6" StrokeLineCap="Round"
                                              IsVisible="{Binding !IsMuted}" />
                                        <Path Data="M 88,16 A 42,42 0 0 1 88,84" Stroke="White" StrokeThickness="6" StrokeLineCap="Round"
                                              IsVisible="{Binding !IsMuted}" />

                                        <!-- Muted State (X) -->
                                        <Path Data="M 72,38 L 92,58 M 92,38 L 72,58" Stroke="White" StrokeThickness="8" StrokeLineCap="Round"
                                              IsVisible="{Binding IsMuted}" />
                                    </Canvas>
                                </Viewbox>
                            </Button>
                        </StackPanel>
                        
                        <!-- Right side toggles: only show when there's enough width to avoid overcrowding -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0">
                            <!-- Visualizer toggle -->
                            <ToggleButton Height="26"
                                          Width="26"
                                          VerticalAlignment="Center"
                                          Cursor="Hand"
                                          ToolTip.Tip="Visualizer"
                                          Command="{Binding ToggleVisualizerCommand}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" BorderThickness="0">
                                            <ContentPresenter Content="{TemplateBinding Content}"
                                                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Viewbox Stretch="Uniform">
                                    <Canvas Width="140" Height="120">
                                        <Rectangle Canvas.Left="16" Canvas.Top="36" Width="14" Height="68" RadiusX="7" RadiusY="7" Fill="{Binding IsVisualizerActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='White,DimGray'}" />
                                        <Rectangle Canvas.Left="40" Canvas.Top="4"  Width="14" Height="100" RadiusX="7" RadiusY="7" Fill="{Binding IsVisualizerActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='White,DimGray'}" />
                                        <Rectangle Canvas.Left="64" Canvas.Top="24" Width="14" Height="80" RadiusX="7" RadiusY="7" Fill="{Binding IsVisualizerActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='White,DimGray'}" />
                                        <Rectangle Canvas.Left="88" Canvas.Top="0"  Width="14" Height="104" RadiusX="7" RadiusY="7" Fill="{Binding IsVisualizerActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='White,DimGray'}" />
                                        <Rectangle Canvas.Left="112" Canvas.Top="36" Width="14" Height="68" RadiusX="7" RadiusY="7" Fill="{Binding IsVisualizerActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='White,DimGray'}" />
                                    </Canvas>
                                </Viewbox>
                            </ToggleButton>

                            <!-- Equalizer toggle -->
                            <ToggleButton Height="26"
                                          Width="26"
                                          VerticalAlignment="Center"
                                          Cursor="Hand"
                                          ToolTip.Tip="Equalizer"
                                          Margin="6,0,0,0"
                                          Command="{Binding ToggleEqualizerCommand}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" BorderThickness="0">
                                            <ContentPresenter Content="{TemplateBinding Content}"
                                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Viewbox Stretch="Uniform">
                                    <Canvas Width="140" Height="120">
                                        <!-- Left slider -->
                                        <Rectangle Canvas.Left="18" Canvas.Top="10" Width="12" Height="100" RadiusX="6" RadiusY="6" Fill="{Binding IsEqualizerActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='White,DimGray'}" />
                                        <Ellipse   Canvas.Left="6"  Canvas.Top="34" Width="36" Height="36" Fill="{Binding IsEqualizerActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='White,DimGray'}" />

                                        <!-- Center slider -->
                                        <Rectangle Canvas.Left="56" Canvas.Top="6"  Width="12" Height="110" RadiusX="6" RadiusY="6" Fill="{Binding IsEqualizerActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='White,DimGray'}" />
                                        <Ellipse   Canvas.Left="44" Canvas.Top="58" Width="36" Height="36" Fill="{Binding IsEqualizerActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='White,DimGray'}" />

                                        <!-- Right slider -->
                                        <Rectangle Canvas.Left="96" Canvas.Top="10" Width="12" Height="100" RadiusX="6" RadiusY="6" Fill="{Binding IsEqualizerActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='White,DimGray'}" />
                                        <Ellipse   Canvas.Left="84" Canvas.Top="34" Width="36" Height="36" Fill="{Binding IsEqualizerActive, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='White,DimGray'}" />
                                    </Canvas>
                                </Viewbox>
                            </ToggleButton>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Player slider -->
                    <composition:CompositionSlider Height="23"
                                                   Minimum="0"
                                                   Maximum="{Binding MusicViewModel.AudioPlayer.Duration, FallbackValue=1}"
                                                   Value="{Binding MusicViewModel.AudioPlayer.Position, Mode=TwoWay}"
                                                   SetValueCommand="{Binding SetPositionCommand}"
                                                   ExecuteDuringDrag="True"
                                                   SliderTrackHeight="13"
                                                   PlayedAreaBrush="{Binding ControlsBrush, TargetNullValue=#007DF9}"
                                                   Margin="-10,0,-5,0"/>
                </StackPanel>
            </StackPanel>
        </Grid>
        
        <!-- Equalizer -->
        <Grid Grid.Row="1" MaxHeight="180">
            <!-- Behaviors -->
			<Interaction.Behaviors>
				<behaviors:MaxHeightToggleBehavior IsOpen="{Binding !ExtensionAreaOpen}"/>
			</Interaction.Behaviors>
            <Grid.Transitions>
				<Transitions>
					<DoubleTransition Property="MaxHeight" Duration="0:0:0.62" Easing="QuadraticEaseInOut"/>
				</Transitions>
			</Grid.Transitions>
            <!-- Templates -->
            <Grid.Resources>
				<DataTemplate x:Key="MiniEqualizerViewModel" DataType="vm:MiniEqualizerViewModel">
                    <local:MiniEqualizerView/>
                </DataTemplate>
            </Grid.Resources>
            <!-- Content -->
            <ContentControl Content="{Binding ExtensionView}"
                            ContentTemplate="{StaticResource MiniEqualizerViewModel}"/>
        </Grid>
        
        <!-- Cover -->
        <Border Opacity="0.4" Grid.Row="2" >
			<Image Source="{Binding LoadedMediaItem.CoverBitmap}" 
                   Stretch="UniformToFill" 
                   IsVisible="{Binding !IsCoverPlaceholder}">
                <Image.OpacityMask>
                    <LinearGradientBrush StartPoint="50%,80%" EndPoint="50%,1%">
                        <GradientStop Offset="0" Color="#FF000000" />  
                        <GradientStop Offset="1" Color="Transparent" /> 
                    </LinearGradientBrush>
                </Image.OpacityMask>
            </Image>
        </Border>

        <!--Albums-->
        <Grid Grid.Row="2"
              IsVisible="{Binding ShowPlaylist}"
              RowDefinitions="Auto,*">
            <!-- Selected Album Info -->
            <Grid Grid.Row="0" Margin="10" ColumnDefinitions="Auto,*">
                <Border Grid.Column="0" Width="60" Height="60" ClipToBounds="True" BorderBrush="DimGray" BorderThickness="1">
                    <composition:FolderCompositionControl Items="{Binding MusicViewModel.SelectedAlbum.Children}"
                                                          FolderCoverItem="{Binding MusicViewModel.SelectedAlbum}"
                                                          DefaultCover="{Binding MusicViewModel.DefaultFolderCover}"
                                                          MaxVisibleCovers="3"
                                                          Margin="1"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{Binding MusicViewModel.SelectedAlbum.Title, FallbackValue='No Album Selected'}"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="Bold"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding MusicViewModel.SelectedAlbum.Children.Count, StringFormat='{}{0} Tracks', FallbackValue='0 Tracks'}"
                               Foreground="DimGray"
                               FontSize="12"/>
                </StackPanel>
            </Grid>

            <!-- Album List -->
            <ListBox Grid.Row="1" Background="Transparent"
                     ItemsSource="{Binding MusicViewModel.AlbumList}"
                     SelectedItem="{Binding MusicViewModel.SelectedAlbum, Mode=TwoWay}"
                     Padding="5"
                     Grid.IsSharedSizeScope="True">
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Scan Folders" Command="{Binding MusicViewModel.ScanFoldersCommand}" />
                        <MenuItem Header="Add Folder" Command="{Binding MusicViewModel.OpenFolderCommand}" />
                    </ContextMenu>
                </ListBox.ContextMenu>
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <ControlTemplate TargetType="ListBoxItem">
                                <Grid Background="Transparent">
                                    <Border x:Name="SelectionBackground"
                                            Background="{Binding ((vm:MinViewModel)DataContext).SelectionBrush, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            IsVisible="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"/>
                                    <ContentPresenter Content="{TemplateBinding Content}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                </Grid>
                            </ControlTemplate>
                        </Setter>
                    </Style>
                </ListBox.Styles>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2" Background="Transparent" Opacity="0.8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="AlbumIndexColumn" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="AlbumDurationColumn" />
                            </Grid.ColumnDefinitions>

                            <!-- Name Placeholder (Or Folder Icon) -->
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Right" 
                                       Foreground="DimGray" FontSize="12" Margin="6,0,6,0" Text="📁" />

                            <!-- Album Title -->
                            <TextBlock Grid.Column="1" Text="{Binding Title}" 
                                       IsVisible="{Binding !IsRenaming}"
                                       Foreground="White" FontSize="12" 
                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="6,0" />

                            <TextBox Grid.Column="1" Text="{Binding Title, Mode=TwoWay}"
                                     IsVisible="{Binding IsRenaming}"
                                     Foreground="White" FontSize="12"
                                     VerticalAlignment="Center" Margin="6,0" />

                            <!-- Total Tracks -->
                            <TextBlock Grid.Column="3" Text="{Binding Children.Count, StringFormat='{}{0} Tracks'}" 
                                       Foreground="White" FontSize="12" Margin="6,0,10,0" 
                                       HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                
                <Interaction.Behaviors>
                    <ExecuteCommandOnDoubleTappedBehavior Command="{Binding MusicViewModel.OpenSelectedFolderCommand}"/>
                </Interaction.Behaviors>
            </ListBox>
        </Grid>
        
        <!-- Playlist -->
        <ListBox Grid.Row="2" Background="Transparent"
                 ItemsSource="{Binding FilteredMediaItems}"
                 SelectedItem="{Binding SelectedMediaItem}"
                 SelectedItems="{Binding SelectedItems, Mode=TwoWay}"
                 SelectionMode="Multiple"
                 BorderBrush="DimGray"
                 BorderThickness="0.5,0,0,0.5"
                 Padding="5"
                 Grid.IsSharedSizeScope="True"
                 IsVisible="{Binding !ShowPlaylist}">

            <!-- Right-click context menu: same actions as the Add button -->
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Add Files" Command="{Binding AddFilesCommand}" />
                    <MenuItem Header="Add Folder" Command="{Binding AddFoldersCommand}" />
                    <Separator />
                    <MenuItem Header="Delete Selected Items" Command="{Binding DeleteSelectedItemsCommand}" />
                </ContextMenu>
            </ListBox.ContextMenu>

            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <Setter Property="Template">
                        <ControlTemplate TargetType="ListBoxItem">
                            <!-- Base selection/background layer -->
                            <Grid Background="Transparent">
                                <Border x:Name="SelectionBackground"
                                        Background="{Binding ((vm:MinViewModel)DataContext).SelectionBrush, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        Padding="{TemplateBinding Padding}"
                                        IsHitTestVisible="{TemplateBinding IsHitTestVisible}"
                                        IsVisible="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"/>
                                <Border Background="{Binding ((vm:MinViewModel)DataContext).LoadedBrush, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        Padding="{TemplateBinding Padding}"
                                        IsHitTestVisible="False">
                                    <Border.IsVisible>
                                        <MultiBinding Converter="{StaticResource ObjectEqualsConverter}">
                                            <Binding Path="." />
                                            <Binding Path="((vm:MinViewModel)DataContext).LoadedMediaItem" RelativeSource="{RelativeSource AncestorType=ListBox}" />
                                        </MultiBinding>
                                    </Border.IsVisible>
                                </Border>
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Grid>
                        </ControlTemplate>
                    </Setter>
                </Style>
            </ListBox.Styles>

            <!-- Behaviors -->
		    <Interaction.Behaviors>
			    <ExecuteCommandOnDoubleTappedBehavior Command="{Binding PlaySelectedMediaItemCommand}"
												      CommandParameter="{Binding SelectedMediaItem}"/>

                <ExecuteCommandOnKeyUpBehavior Key="Delete"
                                               Command="{Binding DeleteSelectedItemsCommand}"
                                               CommandParameter="{Binding SelectedItems}"/>

                <controlsbehaviors:ListboxItemDragBehavior DropCommand="{Binding DropCommand}"/>
		    </Interaction.Behaviors>

            <!-- Playlist item template -->
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0" Background="Transparent" Opacity="0.7">
                        <Grid.ColumnDefinitions>
                            <!-- Index column: use a SharedSizeGroup so all items reserve the same width -->
                            <ColumnDefinition Width="Auto" SharedSizeGroup="IndexColumn" />
                            <!-- Title column -->
                            <ColumnDefinition Width="*" />
                            <!-- small spacer column to separate title and duration -->
                            <ColumnDefinition Width="8" />
                            <!-- SharedSizeGroup ensures every item's second column measures to the widest value -->
                            <ColumnDefinition Width="Auto" SharedSizeGroup="DurationColumn" />
                        </Grid.ColumnDefinitions>

                        <!-- Row index (1-based) - bind directly to MediaItem.Index so updates notify correctly -->
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="White" FontSize="12" Margin="6,0,6,0"
                                   Text="{Binding Index, StringFormat='{}{0}.', FallbackValue=''}" />

                        <Border Grid.Column="1" Margin="6,4" Background="Transparent" ClipToBounds="True">
                            <TextBlock Foreground="White" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} - {1}">
                                        <Binding Path="Title" />
                                        <Binding Path="Album" TargetNullValue="" FallbackValue="" />
                                    </MultiBinding>
                                </TextBlock.Text>
                                <Interaction.Behaviors>
                                    <behaviors:MarqueeBehavior IsActive="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" />
                                </Interaction.Behaviors>
                            </TextBlock>
                        </Border>
                        <TextBlock Grid.Column="3" Text="{Binding Duration, Converter={StaticResource TimeSpanConverter}}" Foreground="White" FontSize="12" Margin="6,4,10,4" HorizontalAlignment="Left" VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Footer -->
        <Grid Grid.Row="3" Height="28">
            <!-- three columns: left controls, search+settings area, resize grip -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="DimGray" BorderThickness="0,0.6,0,0" Margin="1,0,1,0" Grid.ColumnSpan="3"/>

            <StackPanel Grid.Column="0" Margin="5,0,0,0" Spacing="5" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">

                <!-- Add button (uses same add icon as MusicView context menu) -->
                <Button Width="20"
                        Height="20"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        ToolTip.Tip="Add Items">
                    <Button.Flyout>
                        <MenuFlyout Placement="BottomEdgeAlignedLeft">
                            <MenuItem Header="Add Files" Command="{Binding AddFilesCommand}" />
                            <MenuItem Header="Add Folder" Command="{Binding AddFoldersCommand}" />
                        </MenuFlyout>
                    </Button.Flyout>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" BorderThickness="0">
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Viewbox Stretch="Uniform">
                        <Canvas Width="100" Height="100">
                            <!-- Rounded frame -->
                            <Rectangle Canvas.Left="10" Canvas.Top="10" Width="80" Height="80" RadiusX="22" RadiusY="22" Stroke="#CCFFFFFF" StrokeThickness="8" Fill="Transparent" />
                            <!-- Central plus sign -->
                            <Rectangle Canvas.Left="46" Canvas.Top="34" Width="8" Height="32" RadiusX="4" RadiusY="4" Fill="#CCFFFFFF" />
                            <Rectangle Canvas.Left="34" Canvas.Top="46" Width="32" Height="8" RadiusX="4" RadiusY="4" Fill="#CCFFFFFF" />
                        </Canvas>
                    </Viewbox>
                </Button>

                <!-- Playlist toggle -->
                <ToggleButton Height="20"
                              Width="20"
                              VerticalAlignment="Center"
                              Cursor="Hand"
                              ToolTip.Tip="Playlist"
                              IsChecked="{Binding ShowPlaylist, Mode=TwoWay}"
                              Margin="5,0,2,0">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border Background="Transparent" BorderThickness="0">
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                        </ControlTemplate>
                    </ToggleButton.Template>
                    <Viewbox Stretch="Uniform">
                        <Canvas Width="100" Height="100">
                            <Rectangle Canvas.Left="6" Canvas.Top="22" Width="24" Height="24" RadiusX="2" RadiusY="2" Fill="{Binding ShowPlaylist, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='White,DimGray'}" />
                            <Rectangle Canvas.Left="38" Canvas.Top="22" Width="24" Height="24" RadiusX="2" RadiusY="2" Fill="{Binding ShowPlaylist, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='White,DimGray'}" />
                            <Rectangle Canvas.Left="70" Canvas.Top="22" Width="24" Height="24" RadiusX="2" RadiusY="2" Fill="{Binding ShowPlaylist, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='White,DimGray'}" />
                            <Rectangle Canvas.Left="6" Canvas.Top="54" Width="24" Height="24" RadiusX="2" RadiusY="2" Fill="{Binding ShowPlaylist, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='White,DimGray'}" />
                            <Rectangle Canvas.Left="38" Canvas.Top="54" Width="24" Height="24" RadiusX="2" RadiusY="2" Fill="{Binding ShowPlaylist, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='White,DimGray'}" />
                            <Rectangle Canvas.Left="70" Canvas.Top="54" Width="24" Height="24" RadiusX="2" RadiusY="2" Fill="{Binding ShowPlaylist, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='White,DimGray'}" />
                        </Canvas>
                    </Viewbox>
                </ToggleButton>

                <!-- Eject button -->
                <Button Width="24" 
                        Height="24" 
                        Cursor="Hand" 
                        ToolTip.Tip="Eject"
                        Command="{Binding EjectCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" BorderThickness="0">
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Viewbox Stretch="Uniform">
                        <TextBlock Text="⏏️" FontSize="14" Foreground="#BDBDBD" VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Viewbox>
                </Button>
            </StackPanel>

            <!-- search + settings panel -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Spacing="4" Margin="0,0,4,0" Panel.ZIndex="1">
                <!-- Search box -->
                <TextBox Watermark="Search"
                         Text="{Binding SearchText, Mode=TwoWay}"
                         Classes="AlbumSearch"
                         Height="18"
                         MaxHeight="18"
                         FontSize="10"
                         Cursor="Hand"
                         MaxWidth="200">
                    <TextBox.Styles>
                        <Style Selector="TextBox.AlbumSearch">
                            <Setter Property="Width" Value="35"/>
                            <Setter Property="Height" Value="18"/>
                            <Setter Property="MinWidth" Value="35"/>
                            <Setter Property="MinHeight" Value="18"/>
                            <Setter Property="FontSize" Value="10"/>
                            <Setter Property="Transitions">
                                <Transitions>
                                    <DoubleTransition Property="Width" Duration="0:0:0.35" Easing="CubicEaseOut"/>
                                    <ThicknessTransition Property="Padding" Duration="0:0:0.35" Easing="CubicEaseOut"/>
                                    <BrushTransition Property="Background" Duration="0:0:0.35"/>
                                    <BrushTransition Property="BorderBrush" Duration="0:0:0.35"/>
                                </Transitions>
                            </Setter>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="CornerRadius" Value="10"/>
                            <Setter Property="Padding" Value="0,0,5,0"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="Transparent"/>
                        </Style>
                        <Style Selector="TextBox.AlbumSearch:pointerover, TextBox.AlbumSearch:focus">
                            <!-- expand to reasonable size (~40% of typical footer) -->
                            <Setter Property="Width" Value="150"/>
                            <Setter Property="Background" Value="#AA000000"/>
                            <Setter Property="BorderBrush" Value="#44FFFFFF"/>
                            <Setter Property="Padding" Value="6,0,3,0"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                        <Style Selector="TextBox.AlbumSearch /template/ TextBlock#PART_Watermark">
                            <Setter Property="Opacity" Value="0"/>
                            <Setter Property="Transitions">
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                                </Transitions>
                            </Setter>
                        </Style>
                        <Style Selector="TextBox.AlbumSearch:pointerover /template/ TextBlock#PART_Watermark, TextBox.AlbumSearch:focus /template/ TextBlock#PART_Watermark">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Style>
                        <Style Selector="TextBox.AlbumSearch /template/ Border#PART_BorderElement">
                            <Setter Property="CornerRadius" Value="10"/>
                            <Setter Property="Transitions">
                                <Transitions>
                                    <BrushTransition Property="Background" Duration="0:0:0.35"/>
                                    <BrushTransition Property="BorderBrush" Duration="0:0:0.35"/>
                                </Transitions>
                            </Setter>
                        </Style>
                    </TextBox.Styles>
                    <TextBox.InnerLeftContent>
                        <Path Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                              Fill="#CCFFFFFF"
                              Stretch="Uniform"
                              Width="12"
                              Height="12"
                              Margin="6,0,4,0"
                              VerticalAlignment="Center"
                              IsHitTestVisible="False"/>
                    </TextBox.InnerLeftContent>
                    <TextBox.InnerRightContent>
                        <Button Command="{Binding ClearSearchCommand}"
                                IsVisible="{Binding SearchText, Converter={StaticResource StringNotEmptyToBoolConverter}}"
                                Background="Transparent"
                                Margin="0,0,4,0"
                                Width="18"
                                Cursor="Hand"
                                Focusable="False">
                            <Button.Template>
                                <ControlTemplate>
                                    <Grid Background="Transparent">
                                        <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                                              Fill="#AAFFFFFF"
                                              Stretch="Uniform"
                                              Width="8"
                                              Height="8"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                                    </Grid>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </TextBox.InnerRightContent>
                </TextBox>

                <!-- Settings icon -->
                <Button Height="26"
                        Width="26"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        ToolTip.Tip="Settings"
                        Command="{Binding ToggleSettingsCommand}"
                        Margin="4,0,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" BorderThickness="0">
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Viewbox Stretch="Uniform" Width="14" Height="14" Margin="0,0,0,2">
                        <Path Fill="#BDBDBD" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center" Width="28" Height="28" Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.98C19.47,12.66 19.5,12.34 19.5,12C19.5,11.66 19.47,11.34 19.43,11.02L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.65 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.65 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11.02C4.53,11.34 4.5,11.66 4.5,12C4.5,12.34 4.53,12.66 4.57,12.98L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.98Z" />
                    </Viewbox>
                </Button>
            </StackPanel>

            <!-- count/total info stays centered across first two columns -->
            <TextBlock Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#BDBDBD" FontSize="12">
                <Run Text="{Binding LoadedMediaItem.Index, FallbackValue=0}" />
                <Run Text=" of " />
                <Run Text="{Binding FilteredMediaItems.Count, FallbackValue=0}" />
                <Run Text=" - " />
                <Run Text="{Binding TotalDuration, Converter={StaticResource TimeSpanConverter}, FallbackValue=''}" />
            </TextBlock>

            <!-- Resize grip dots at bottom-right - triangular (pointing to bottom-right) -->
            <Canvas Grid.Column="2" HorizontalAlignment="Right" Margin="0,0,0,7" VerticalAlignment="Bottom" Width="24" Height="18" IsHitTestVisible="False">
                <!-- Top row (single dot, near right) -->
                <Ellipse Width="3" Height="3" Fill="#BDBDBD" Canvas.Left="16" Canvas.Top="3" />

                <!-- Middle row (two dots) -->
                <Ellipse Width="3" Height="3" Fill="#BDBDBD" Canvas.Left="11" Canvas.Top="9" />
                <Ellipse Width="3" Height="3" Fill="#BDBDBD" Canvas.Left="16" Canvas.Top="9" />

                <!-- Bottom row (three dots) -->
                <Ellipse Width="3" Height="3" Fill="#BDBDBD" Canvas.Left="6" Canvas.Top="15" />
                <Ellipse Width="3" Height="3" Fill="#BDBDBD" Canvas.Left="11" Canvas.Top="15" />
                <Ellipse Width="3" Height="3" Fill="#BDBDBD" Canvas.Left="16" Canvas.Top="15" />
            </Canvas>
        </Grid>
    </Grid>
</UserControl>