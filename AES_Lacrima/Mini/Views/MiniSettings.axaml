<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="using:AES_Lacrima.ViewModels"
             xmlns:behavors="using:AES_Controls.Behaviors"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AES_Lacrima.Mini.Views.MiniSettings"
             x:DataType="viewmodels:SettingsViewModel">
    <Grid>
        <TabControl>
            <TabItem Header="Audio">
			    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10,12,8,8" Spacing="8" HorizontalAlignment="Left" VerticalAlignment="Top">
                        <StackPanel Orientation="Vertical" Margin="0,6,0,0" Spacing="6">
                            <!-- Volume processing options -->
                            <StackPanel Orientation="Vertical" Spacing="4" Margin="0,0,0,10">
                                <CheckBox IsChecked="{Binding SmoothVolumeChange, Mode=TwoWay}" VerticalAlignment="Center">
                                    <TextBlock Text="Smooth volume changing" Foreground="WhiteSmoke" VerticalAlignment="Center"/>
                                </CheckBox>
                                <CheckBox IsChecked="{Binding LogarithmicVolumeControl, Mode=TwoWay}" VerticalAlignment="Center">
                                    <TextBlock Text="Logarithmic volume control" Foreground="WhiteSmoke" VerticalAlignment="Center"/>
                                </CheckBox>
                                <CheckBox IsChecked="{Binding LoudnessCompensatedVolume, Mode=TwoWay}" VerticalAlignment="Center">
                                    <TextBlock Text="Loudness compensated volume control" Foreground="WhiteSmoke" VerticalAlignment="Center"/>
                                </CheckBox>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                                <TextBlock Text="Enable ReplayGain" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="16"/>
                                <ToggleSwitch IsChecked="{Binding ReplayGainEnabled, Mode=TwoWay}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,4,0,4" Spacing="10">
                                <TextBlock Text="Silence advance delay (ms):" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="14"/>
                                <TextBox Width="80" Text="{Binding SilenceAdvanceDelayMs, Mode=TwoWay}">
                                    <Interaction.Behaviors>
                                        <behavors:DigitOnlyBehavior/>
                                    </Interaction.Behaviors>
                                </TextBox>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" Margin="0,4,0,0" Spacing="4">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                                    <CheckBox IsChecked="{Binding ReplayGainAnalyzeOnTheFly, Mode=TwoWay}" VerticalAlignment="Center"/>
                                    <TextBlock Text="Analyse file on-the-fly" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="14"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                                    <TextBlock Text="Preamp (dB):" VerticalAlignment="Center" Foreground="WhiteSmoke"/>
                                    <Slider Width="260" Minimum="-12" Maximum="12" Value="{Binding ReplayGainPreampDb, Mode=TwoWay}"/>
                                    <TextBlock Text="{Binding ReplayGainPreampDb, StringFormat='{}{0:0.##} dB'}" VerticalAlignment="Center" Foreground="WhiteSmoke" Margin="8,0,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,4,0,0" Spacing="4">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                                    <CheckBox IsChecked="{Binding ReplayGainUseTags, Mode=TwoWay}" VerticalAlignment="Center"/>
                                    <TextBlock Text="Use value from tags" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="14"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                                    <TextBlock Text="Preamp (dB):" VerticalAlignment="Center" Foreground="WhiteSmoke"/>
                                    <Slider Width="200" Minimum="-12" Maximum="12" Value="{Binding ReplayGainTagsPreampDb, Mode=TwoWay}"/>
                                    <TextBlock Text="{Binding ReplayGainTagsPreampDb, StringFormat='{}{0:0.##} dB'}" VerticalAlignment="Center" Foreground="WhiteSmoke" Margin="8,0,0,0"/>
                                    <ComboBox Width="120" SelectedIndex="{Binding ReplayGainTagSource, Mode=TwoWay}" Margin="12,0,0,0">
                                        <ComboBoxItem>Track</ComboBoxItem>
                                        <ComboBoxItem>Album</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
			<TabItem Header="Libraries">
				<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10,12,8,8" Spacing="8" HorizontalAlignment="Left" VerticalAlignment="Top">

                        <TextBlock Text="External tools" VerticalAlignment="Center" FontSize="20" Foreground="WhiteSmoke" Margin="0,0,0,6"/>
                        <Separator />

                        <StackPanel Spacing="4" Margin="0,0,0,12">
                            <TextBlock Text="FFmpeg Status" FontSize="16" Foreground="WhiteSmoke"/>
                            <TextBlock Text="{Binding FfmpegManager.Status}" FontSize="14" Foreground="DarkGray"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,0,0,18">
                            <StackPanel Spacing="4">
                                <TextBlock Text="CURRENT VERSION" FontSize="12" Foreground="DarkGray" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding FfmpegVersion, FallbackValue='Not Found'}" FontSize="14" Foreground="WhiteSmoke"/>
                            </StackPanel>
                            <StackPanel Spacing="4" IsVisible="{Binding IsFfmpegUpdateAvailable}">
                                <TextBlock Text="UPDATE AVAILABLE" FontSize="12" Foreground="Gold" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding FfmpegUpdateVersion}" FontSize="14" Foreground="Gold"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Install FFmpeg"
                                    Command="{Binding InstallFFmpegCommand}"
                                    IsVisible="{Binding !IsFfmpegInstalled}"
                                    IsEnabled="{Binding !FfmpegManager.IsBusy}" />

                            <Button Content="Update"
                                    Command="{Binding UpdateFFmpegCommand}"
                                    IsVisible="{Binding IsFfmpegUpdateAvailable}"
                                    IsEnabled="{Binding !FfmpegManager.IsBusy}"
                                    Background="Gold"
                                    Foreground="Black"/>

                            <Button Content="Uninstall"
                                    Background="#F44336"
                                    Foreground="White"
                                    Command="{Binding UninstallFFmpegCommand}"
                                    IsVisible="{Binding IsFfmpegInstalled}"
                                    IsEnabled="{Binding !FfmpegManager.IsBusy}"/>

                            <Button Content="Check for Updates"
                                    Command="{Binding RefreshFFmpegInfoCommand}"
                                    IsEnabled="{Binding !FfmpegManager.IsBusy}"/>
                        </StackPanel>

                        <ProgressBar IsIndeterminate="True"
                                        IsVisible="{Binding FfmpegManager.IsBusy}"
                                        Margin="0,14,0,0" />

                        <TextBlock Text="libmpv Status" FontSize="16" Foreground="WhiteSmoke" Margin="0,18,0,6"/>
                        <Separator />

                        <StackPanel Spacing="8" Margin="0,0,0,12">
                            <TextBlock Text="{Binding MpvManager.Status}" FontSize="14" Foreground="DarkGray"/>

                            <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,0,0,6" IsVisible="{Binding IsMpvInstalled}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="CURRENT VERSION" FontSize="12" Foreground="DarkGray" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding MpvVersion, FallbackValue='Not Found'}" FontSize="14" Foreground="WhiteSmoke"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="Available Versions (Win builds)" VerticalAlignment="Center" FontSize="14" Foreground="WhiteSmoke"/>
                                <ComboBox ItemsSource="{Binding AvailableMpvVersions}" 
                                            SelectedItem="{Binding SelectedMpvVersion}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Install"
                                    Command="{Binding InstallMpvCommand}"
                                    IsVisible="{Binding !IsMpvInstalled}"
                                    IsEnabled="{Binding !MpvManager.IsBusy}" />

                            <Button Content="Force Reinstall Specific"
                                    Command="{Binding InstallSpecificMpvVersionCommand}"
                                    IsEnabled="{Binding !MpvManager.IsBusy}"
                                    Background="Gold"
                                    Foreground="Black"/>

                            <Button Content="Uninstall libmpv"
                                    Background="#F44336"
                                    Foreground="White"
                                    Command="{Binding UninstallMpvCommand}"
                                    IsVisible="{Binding IsMpvInstalled}"
                                    IsEnabled="{Binding !MpvManager.IsBusy}"/>

                            <Button Content="Refresh libmpv Info"
                                    Command="{Binding RefreshMpvInfoCommand}"
                                    IsEnabled="{Binding !MpvManager.IsBusy}"/>
                        </StackPanel>

                        <ProgressBar IsIndeterminate="True"
                                        IsVisible="{Binding MpvManager.IsBusy}"
                                        Margin="0,14,0,0" />

                        <TextBlock Text="yt-dlp Status" FontSize="16" Foreground="WhiteSmoke" Margin="0,18,0,6"/>
                        <Separator />

                        <StackPanel Spacing="8" Margin="0,0,0,12">
                            <TextBlock Text="{Binding YtDlp.Status}" FontSize="14" Foreground="DarkGray"/>

                            <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,0,0,6">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="CURRENT VERSION" FontSize="12" Foreground="DarkGray" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding YtDlpVersion, FallbackValue='Not Found'}" FontSize="14" Foreground="WhiteSmoke"/>
                                </StackPanel>
                                <StackPanel Spacing="4" IsVisible="{Binding IsYtDlpUpdateAvailable}">
                                    <TextBlock Text="UPDATE AVAILABLE" FontSize="12" Foreground="Gold" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding YtDlpUpdateVersion}" FontSize="14" Foreground="Gold"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Install yt-dlp"
                                    Command="{Binding InstallYtDlpCommand}"
                                    IsVisible="{Binding !IsYtDlpInstalled}"
                                    IsEnabled="{Binding !YtDlp.IsBusy}"/>

                            <Button Content="Update"
                                    Command="{Binding UpdateYtDlpCommand}"
                                    IsVisible="{Binding IsYtDlpUpdateAvailable}"
                                    IsEnabled="{Binding !YtDlp.IsBusy}"
                                    Background="Gold"
                                    Foreground="Black"/>

                            <Button Content="Uninstall"
                                    Background="#F44336"
                                    Foreground="White"
                                    Command="{Binding UninstallYtDlpCommand}"
                                    IsVisible="{Binding IsYtDlpInstalled}"
                                    IsEnabled="{Binding !YtDlp.IsBusy}"/>

                            <Button Content="Check for Updates"
                                    Command="{Binding RefreshYtDlpInfoCommand}"
                                    IsEnabled="{Binding !YtDlp.IsBusy}"/>
                        </StackPanel>

                        <ProgressBar IsIndeterminate="True"
                                        IsVisible="{Binding YtDlp.IsBusy}"
                                        Margin="0,14,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
